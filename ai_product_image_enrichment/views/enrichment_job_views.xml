<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="aipie_enrichment_job_form" model="ir.ui.view">
        <field name="name">aipie.enrichment.job.form</field>
        <field name="model">aipie.enrichment.job</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_queue" type="object" string="Queue / Resume" class="btn-primary"
                            invisible="state in ('queued','running','done','cancelled')"/>
                    <button name="action_pause" type="object" string="Pause"
                            invisible="state not in ('queued','running')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('done','cancelled','failed')"/>
                    <button name="action_open_candidates" type="object" string="View Candidates"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="pipeline_steps"/>
                            <field name="dry_run"/>
                        </group>
                        <group>
                            <field name="total_count"/>
                            <field name="processed_count"/>
                            <field name="success_count"/>
                            <field name="failure_count"/>
                            <field name="images_with_white_bg_count"/>
                            <field name="images_required_rembg_count"/>
                            <field name="actual_cost_usd" widget="monetary"/>
                            <field name="started_at"/>
                            <field name="completed_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="product_ids">
                                <list>
                                    <field name="display_name"/>
                                    <field name="default_code"/>
                                    <field name="aipie_enrichment_state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Logs">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="step"/>
                                    <field name="level"/>
                                    <field name="product_id"/>
                                    <field name="message"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="aipie_enrichment_job_list" model="ir.ui.view">
        <field name="name">aipie.enrichment.job.list</field>
        <field name="model">aipie.enrichment.job</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="pipeline_steps"/>
                <field name="state"/>
                <field name="total_count"/>
                <field name="processed_count"/>
                <field name="success_count"/>
                <field name="failure_count"/>
                <field name="actual_cost_usd"/>
            </list>
        </field>
    </record>

    <record id="action_aipie_enrichment_job" model="ir.actions.act_window">
        <field name="name">Enrichment Jobs</field>
        <field name="res_model">aipie.enrichment.job</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
