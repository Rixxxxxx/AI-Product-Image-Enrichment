<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_ai_product_image_enrichment_root" name="AI Images" sequence="90"
              web_icon="ai_product_image_enrichment,static/description/icon.png"/>

    <menuitem id="menu_aipie_jobs" name="Jobs"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_enrichment_job" sequence="10"/>

    <menuitem id="menu_aipie_candidates" name="Candidates"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_candidate" sequence="20"/>

    <menuitem id="menu_aipie_logs" name="Step Logs"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_enrichment_log" sequence="30"/>

    <menuitem id="menu_aipie_ai_usage" name="AI Usage"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_ai_usage_log" sequence="40"/>

    <menuitem id="menu_aipie_recipes" name="Scraping Recipes"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_scraping_recipe" sequence="45"/>

    <record id="action_aipie_enrich_wizard" model="ir.actions.act_window">
        <field name="name">Enrich Products (AI)</field>
        <field name="res_model">aipie.enrich.products.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
    </record>

    <record id="action_aipie_normalize_wizard" model="ir.actions.act_window">
        <field name="name">Normalize Main Images</field>
        <field name="res_model">aipie.normalize.only.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
    </record>

    <menuitem id="menu_aipie_enrich_wiz" name="Enrich Wizard"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_enrich_wizard" sequence="50"/>

    <menuitem id="menu_aipie_normalize_wiz" name="Normalize Wizard"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_normalize_wizard" sequence="60"/>

    <record id="action_aipie_preview_wizard" model="ir.actions.act_window">
        <field name="name">Preview Normalization</field>
        <field name="res_model">aipie.preview.normalization.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_aipie_preview_wiz" name="Preview Normalization"
              parent="menu_ai_product_image_enrichment_root"
              action="action_aipie_preview_wizard" sequence="70"/>
</odoo>
