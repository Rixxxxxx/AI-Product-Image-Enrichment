<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_laudie_image_ai_root" name="AI Images" sequence="90"
              web_icon="laudie_image_ai,static/description/icon.png"/>

    <menuitem id="menu_laudie_jobs" name="Jobs"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_enrichment_job" sequence="10"/>

    <menuitem id="menu_laudie_candidates" name="Candidates"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_candidate" sequence="20"/>

    <menuitem id="menu_laudie_logs" name="Step Logs"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_enrichment_log" sequence="30"/>

    <menuitem id="menu_laudie_ai_usage" name="AI Usage"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_ai_usage_log" sequence="40"/>

    <menuitem id="menu_laudie_recipes" name="Scraping Recipes"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_scraping_recipe" sequence="45"/>

    <record id="action_laudie_enrich_wizard" model="ir.actions.act_window">
        <field name="name">Enrich Products (AI)</field>
        <field name="res_model">laudie.enrich.products.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
    </record>

    <record id="action_laudie_normalize_wizard" model="ir.actions.act_window">
        <field name="name">Normalize Main Images</field>
        <field name="res_model">laudie.normalize.only.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
    </record>

    <menuitem id="menu_laudie_enrich_wiz" name="Enrich Wizard"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_enrich_wizard" sequence="50"/>

    <menuitem id="menu_laudie_normalize_wiz" name="Normalize Wizard"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_normalize_wizard" sequence="60"/>

    <record id="action_laudie_preview_wizard" model="ir.actions.act_window">
        <field name="name">Preview Normalization</field>
        <field name="res_model">laudie.preview.normalization.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_laudie_preview_wiz" name="Preview Normalization"
              parent="menu_laudie_image_ai_root"
              action="action_laudie_preview_wizard" sequence="70"/>
</odoo>
