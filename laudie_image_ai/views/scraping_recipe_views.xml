<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="laudie_scraping_recipe_list" model="ir.ui.view">
        <field name="name">laudie.scraping.recipe.list</field>
        <field name="model">laudie.scraping.recipe</field>
        <field name="arch" type="xml">
            <list>
                <field name="domain"/>
                <field name="success_count"/>
                <field name="recipe_built"/>
                <field name="active"/>
                <field name="consecutive_failures"/>
                <field name="last_built"/>
                <field name="last_validated"/>
            </list>
        </field>
    </record>

    <record id="laudie_scraping_recipe_form" model="ir.ui.view">
        <field name="name">laudie.scraping.recipe.form</field>
        <field name="model">laudie.scraping.recipe</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="domain"/>
                            <field name="active"/>
                            <field name="recipe_built"/>
                            <field name="success_count"/>
                            <field name="consecutive_failures"/>
                        </group>
                        <group>
                            <field name="last_built"/>
                            <field name="last_validated"/>
                            <field name="last_failure"/>
                        </group>
                    </group>
                    <group string="Recipe">
                        <field name="main_image_selector"/>
                        <field name="gallery_image_selector"/>
                        <field name="image_url_attribute"/>
                        <field name="excluded_url_patterns"/>
                        <field name="notes"/>
                    </group>
                    <group string="Raw">
                        <field name="raw_recipe_json" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_laudie_scraping_recipe" model="ir.actions.act_window">
        <field name="name">Scraping Recipes</field>
        <field name="res_model">laudie.scraping.recipe</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
