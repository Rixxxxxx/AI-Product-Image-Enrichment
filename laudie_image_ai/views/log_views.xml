<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="laudie_enrichment_log_list" model="ir.ui.view">
        <field name="name">laudie.enrichment.log.list</field>
        <field name="model">laudie.enrichment.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="job_id"/>
                <field name="product_id"/>
                <field name="step"/>
                <field name="level"/>
                <field name="message"/>
                <field name="duration_ms"/>
            </list>
        </field>
    </record>

    <record id="action_laudie_enrichment_log" model="ir.actions.act_window">
        <field name="name">Enrichment Logs</field>
        <field name="res_model">laudie.enrichment.log</field>
        <field name="view_mode">list</field>
    </record>

    <record id="laudie_ai_usage_log_list" model="ir.ui.view">
        <field name="name">laudie.ai.usage.log.list</field>
        <field name="model">laudie.ai.usage.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="model"/>
                <field name="operation"/>
                <field name="product_id"/>
                <field name="input_tokens"/>
                <field name="output_tokens"/>
                <field name="cost_usd"/>
                <field name="duration_ms"/>
            </list>
        </field>
    </record>

    <record id="action_laudie_ai_usage_log" model="ir.actions.act_window">
        <field name="name">AI Usage</field>
        <field name="res_model">laudie.ai.usage.log</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
